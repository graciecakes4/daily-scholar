# Daily Scholar - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# REQUIRED API KEYS
# =============================================================================

# Anthropic API Key (for Claude)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# OPTIONAL API KEYS (enhanced functionality)
# =============================================================================

# Semantic Scholar API Key (optional - has generous free tier without key)
# Get yours at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# CORE API Key (optional - for broader paper access)
# Get yours at: https://core.ac.uk/services/api
CORE_API_KEY=

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# SQLite database path (relative to project root)
DATABASE_URL=sqlite:///./data/daily_scholar.db

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (set to false in production)
DEBUG=true

# Server host and port
HOST=0.0.0.0
PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# CONTENT GENERATION SETTINGS
# =============================================================================

# Claude model to use for content generation.
# Use a current model name from https://docs.claude.com/en/docs/about-claude/models —
# old aliases stop being served and will 404. Safe current defaults:
#   claude-sonnet-4-5   — strong reasoning, ~$3/Mtok in
#   claude-haiku-4-5    — cheap + fast, fine for summaries and quizzes
CLAUDE_MODEL=claude-sonnet-4-5

# Maximum tokens for generated content
MAX_TOKENS=4096

# =============================================================================
# GOOGLE GEMINI (OPTIONAL) — required if any LLM task routes to gemini or antigravity
# =============================================================================
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Google Antigravity uses the same GEMINI_API_KEY. Leave model empty to use
# the Antigravity SDK's default, or pin to a specific Gemini model:
#   ANTIGRAVITY_MODEL=gemini-2.5-pro
ANTIGRAVITY_MODEL=

# =============================================================================
# PER-TASK LLM ROUTING (OPTIONAL)
# =============================================================================
# Each LLM call site (summary, review, quiz, evaluate) can be pinned to a
# specific provider:model. Empty = use the bundled defaults in
# backend/services/llm/factory.py (DEFAULT_TASK_ROUTING):
#
#   summary  -> anthropic:claude-haiku-4-5   (cheap distillation)
#   review   -> anthropic:claude-sonnet-4-5  (teaching reasoning)
#   quiz     -> anthropic:claude-sonnet-4-5  (careful question construction)
#   evaluate -> anthropic:claude-haiku-4-5   (correctness check)
#
# Supported providers: anthropic, gemini, antigravity
# Override examples:
#   LLM_TASK_SUMMARY=gemini:gemini-2.5-flash
#   LLM_TASK_QUIZ=antigravity:gemini-2.5-pro
#   LLM_TASK_REVIEW=anthropic:claude-opus-4-8

LLM_TASK_SUMMARY=
LLM_TASK_REVIEW=
LLM_TASK_QUIZ=
LLM_TASK_EVALUATE=
LLM_TASK_DEFAULT=

# =============================================================================
# SCHEDULING
# =============================================================================

# Time to generate daily content (24-hour format, in your timezone)
DAILY_GENERATION_TIME=06:00

# Timezone for scheduling
TIMEZONE=America/New_York

# =============================================================================
# FILE STORAGE
# =============================================================================

# Directory for uploaded course materials
UPLOAD_DIR=./uploads

# Maximum upload file size in bytes (50MB default)
MAX_UPLOAD_SIZE=52428800

# =============================================================================
# WEB PUSH (VAPID) — required to send push notifications from the PWA
# =============================================================================
# Generate a keypair ONCE with: python scripts/generate_vapid_keys.py
# Reuse the same keys forever — regenerating invalidates every active
# browser subscription, and clients would have to re-subscribe.

# Public key (browser-side, served via GET /push/vapid-public-key)
VAPID_PUBLIC_KEY=

# Private key (server-side only, never expose)
VAPID_PRIVATE_KEY=

# Identifies the app owner to push providers — mailto: or https:// URL
VAPID_SUBJECT=mailto:you@example.com
